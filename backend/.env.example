# ==================================
# DevPal Backend - Environment Variables
# ==================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo como .env: cp .env.example .env
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. NUNCA commitees el archivo .env a Git
#

# ----------------------------------
# Google Gemini API (OPCIONAL - Para funciones de IA)
# ----------------------------------
# Obtén tu API key en: https://makersuite.google.com/app/apikey
# Si no tienes API key, las funciones de IA estarán bloqueadas
GEMINI_API_KEY=opcional_para_desarrollo

# ----------------------------------
# Database Configuration (PostgreSQL)
# ----------------------------------
# Para desarrollo local usa:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=devpal_db

# Para Azure PostgreSQL usa:
# DB_HOST=your_postgresql_host.postgres.database.azure.com
# DB_USER=your_db_username@your_server
# DB_PASSWORD=your_secure_password_here
# DB_NAME=postgres

# ----------------------------------
# CORS Configuration
# ----------------------------------
# Lista de orígenes permitidos separados por comas
# Desarrollo local:
CORS_ORIGINS=http://localhost:19006,http://localhost:8081
# Producción (REEMPLAZAR):
# CORS_ORIGINS=https://devpal.app,https://api.devpal.app

# ----------------------------------
# Application Settings
# ----------------------------------
# Ambiente: development, staging, production
ENVIRONMENT=development

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Habilitar trabajos programados (generación de noticias/eventos con IA)
# Desactivar en desarrollo local si no tienes GEMINI_API_KEY
ENABLE_SCHEDULED_JOBS=false

# ----------------------------------
# Rate Limiting (Opcional)
# ----------------------------------
RATE_LIMIT_ENABLED=true
# Usar 'memory' para desarrollo, 'redis' para producción
RATE_LIMIT_STORAGE=memory

# ----------------------------------
# Redis (Opcional - para caché en producción)
# ----------------------------------
# REDIS_URL=redis://localhost:6379/0
